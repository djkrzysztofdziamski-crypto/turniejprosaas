# Parametry Cloud Functions (stringi — bez haseł)
# Sekrety ustaw: firebase functions:secrets:set STRIPE_SECRET_KEY itd.
# Skopiuj do .env.turniejprosaas i uzupełnij (plik .env.* jest w .gitignore)

APP_URL=https://app.turniejomat.pl
APP_LANDING_URL=https://turniejomat.pl
STRIPE_PAYMENT_METHOD_TYPES=card,blik
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_SECURE=false
EMAIL_FROM=Turniejomat <noreply@turniejomat.pl>
EMAIL_REPLY_TO=admin@turniejomat.pl
